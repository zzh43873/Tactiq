# Tactiq 环境变量配置示例
# 复制此文件为 .env 并填写你的配置

# ============================================
# 应用配置
# ============================================
APP_NAME=Tactiq System
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# 数据库配置
# ============================================
# 开发环境使用 SQLite (无需安装 PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./tactiq.db

# Docker/生产环境使用 PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/geopolitics

DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=geopolitics

# ============================================
# Redis配置
# ============================================
# Docker环境使用
REDIS_URL=redis://redis:6379/0

# 本地开发环境使用
# REDIS_URL=redis://localhost:6379/0

REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# LLM API配置 (至少配置一个)
# ============================================

# OpenAI (推荐)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# DeepSeek (国内可用)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# SiliconFlow (国内可用)
# SILICONFLOW_API_KEY=your-siliconflow-api-key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# ============================================
# 外部数据源配置 (可选)
# ============================================
NEWSAPI_KEY=your-newsapi-key

# ============================================
# Celery配置
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# 推演配置
# ============================================
SIMULATION_MAX_ROUNDS=5
SIMULATION_TIMEOUT=300
